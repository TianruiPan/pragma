{
  "schemaVersion": "2.0",
  "kind": "pragma-visual-baseline",
  "viewports": [
    {
      "id": "desktop-1920",
      "width": 1920,
      "height": 1080,
      "deviceScale": 1,
      "baselineScreenshot": "screenshots/main-frame.webp",
      "diffThreshold": {
        "pixelRatio": 0.02,
        "ignoreRegions": [
          "region-dynamic-map-surface-node-1-30-dynamic"
        ],
        "warnOnlyRegions": []
      }
    }
  ],
  "strategy": "screenshot-diff-for-reference",
  "humanReviewRequired": true
}
