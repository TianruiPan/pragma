{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pragma.local/schemas/pragma-2.0/manifest.schema.json",
  "title": "Pragma 2.0 Design Context Package Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "integrationContractVersion",
    "kind",
    "id",
    "version",
    "packageChecksum",
    "issue",
    "linkedDevelopmentIssues",
    "source",
    "entrypoints",
    "artifact"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "integrationContractVersion": {
      "const": "pragma-integration/v2"
    },
    "kind": {
      "const": "pragma-design-context-package"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^v[1-9][0-9]*$"
    },
    "packageChecksum": {
      "type": "string",
      "pattern": "^sha256:[0-9a-fA-F]{64}$"
    },
    "issue": {
      "type": "object",
      "required": [
        "provider",
        "repo",
        "number",
        "type"
      ],
      "properties": {
        "provider": {
          "const": "gitea"
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "type": {
          "const": "design"
        },
        "title": {
          "type": "string"
        },
        "targetDevIssues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "number"
            ],
            "properties": {
              "number": {
                "type": "integer",
                "minimum": 1
              },
              "title": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "linkedDevelopmentIssues": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1
      },
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "required": [
        "provider",
        "adapter",
        "capturedAt"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "adapter": {
          "type": "string",
          "minLength": 1
        },
        "fileKey": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "capturedAt": {
          "type": "string"
        },
        "sourceChecksum": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "entrypoints": {
      "type": "object",
      "required": [
        "humanHandoff",
        "agentContext",
        "agentWorkflow",
        "designContext",
        "pixelSpec",
        "layers",
        "tokens",
        "components",
        "dependencies",
        "assetsManifest",
        "renderInstructions",
        "visualBaseline",
        "assetsDir",
        "screenshots"
      ],
      "properties": {
        "humanHandoff": {
          "type": "string"
        },
        "lanhuUrl": {
          "type": "string"
        },
        "agentContext": {
          "type": "string"
        },
        "agentWorkflow": {
          "type": "string"
        },
        "designContext": {
          "type": "string"
        },
        "assetsManifest": {
          "type": "string"
        },
        "assetsDir": {
          "type": "string"
        },
        "screenshots": {
          "type": "string"
        },
        "pixelSpec": {
          "type": "string"
        },
        "layers": {
          "type": "string"
        },
        "tokens": {
          "type": "string"
        },
        "components": {
          "type": "string"
        },
        "dependencies": {
          "type": "string"
        },
        "renderInstructions": {
          "type": "string"
        },
        "visualBaseline": {
          "type": "string"
        },
        "sourceDesignContext": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "artifact": {
      "type": "object",
      "required": [
        "storage"
      ],
      "properties": {
        "storage": {
          "enum": [
            "repo",
            "minio-s3"
          ]
        },
        "path": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "bucket": {
          "type": "string"
        },
        "objectKey": {
          "type": "string"
        },
        "fileName": {
          "type": [
            "string",
            "null"
          ]
        },
        "uri": {
          "type": "string"
        },
        "archiveSizeBytes": {
          "type": "integer",
          "minimum": 1
        },
        "checksum": {
          "type": "string",
          "pattern": "^sha256:[0-9a-fA-F]{64}$"
        },
        "publishedAt": {
          "type": "string"
        },
        "dryRun": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "storage": {
                "const": "repo"
              }
            }
          },
          "then": {
            "required": [
              "path",
              "checksum"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "storage": {
                "const": "minio-s3"
              }
            }
          },
          "then": {
            "required": [
              "bucket",
              "objectKey",
              "uri",
              "fileName",
              "checksum",
              "archiveSizeBytes"
            ]
          }
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
